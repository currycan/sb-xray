# ==============================================================================
# .dockerignore — Docker 构建上下文过滤规则
#
# 仅 scripts/、templates/、sources/ 三个目录会被 COPY 进镜像，
# 其余所有文件默认排除，以下按类别列出。
# 注意: Docker 的 *.ext 仅匹配根目录；子目录用 **/*.ext 匹配。
# ==============================================================================

# ── 构建/发布工具（镜像内不需要）──────────────────────────────────────────────
Dockerfile
docker-compose.yml
build.sh
release.sh

# ── Git 相关 ──────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── 开发工具配置 ──────────────────────────────────────────────────────────────
.agents/
.claude/
.gemini/
.idea/
.vscode/
.editorconfig
.prettierignore

# ── 文档与说明 ────────────────────────────────────────────────────────────────
CLAUDE.md
docs/
*.md
**/*.md

# ── 测试文件（仅本地开发使用）────────────────────────────────────────────────
scripts/test_entrypoint.sh
test_rename.js

# ── 项目元信息 ────────────────────────────────────────────────────────────────
LICENSE

# ── macOS 元数据 ─────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── 临时文件与运行时输出 ──────────────────────────────────────────────────────
tmp/
ag_output_*.txt
