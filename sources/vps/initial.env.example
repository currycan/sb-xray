# initial.env.example —— vps-init.sh（Stage 1）的配置模板；Stage 1/2 共用的节点唯一输入
#
# 用法：复制为同目录 initial.env 并填值，initial.sh 启动时自动 source。
#   cp initial.env.example initial.env && vi initial.env
# 真实 initial.env 含凭据，已被 .gitignore 排除，请勿入库。
#
# ⚠️ 本文件按 shell 语法被 source：值含空格/特殊字符（如 SSH 公钥、含符号的密码/code）
#    必须用引号包起来，否则 source 会报错（把值当命令执行）。
#
# 安全：脚本 source 本文件而非走命令行，敏感值不进进程表/shell 历史。
#   所有项也可用环境变量在运行时覆盖本文件。

# ── 部署目录 ──────────────────────────────────────────────
SBXRAY_DIR=/root/sb-xray          # sb-xray 部署目录（与 Stage 2 默认一致）

# ── sudo 用户 ─────────────────────────────────────────────
SBX_USER=sbx                      # 要创建的 sudo 用户名
SBX_USER_PASSWORD=                # 空=不设密码（仅密钥登录，推荐留空）；含特殊字符须加引号
ROOT_PASSWORD=                    # 空=不改 root 密码；含特殊字符须加引号

# ── SSH（仅密钥策略）─────────────────────────────────────
# 注意：脚本会关闭密码登录、仅保留公钥登录。必须提供至少一个有效公钥，
#       否则脚本在配置 SSH 前中止（防锁机）。
#
# 推荐用 ed25519，而非 RSA：公钥更短、握手更快、更安全。生成：
#   ssh-keygen -t ed25519 -C "you@host"
#
# 提供方式二选一（SSH_PUBKEY_FILE 更省事，免引号、且支持多公钥）：
#   1) SSH_PUBKEY_FILE 指向 .pub 或 authorized_keys 文件，装入其中全部有效公钥行
#   2) SSH_PUBKEY 内联单个公钥（含空格，必须加引号）
SSH_PORT=38666
SSH_PUBKEY_FILE=                  # 如 /root/keys/admins.pub（每行一个公钥，支持多把）
SSH_PUBKEY=""                     # 形如 "ssh-ed25519 AAAA... comment"

# ── 系统 ─────────────────────────────────────────────────
TIMEZONE=Asia/Shanghai

# ── sb-xray 部署（写入 $SBXRAY_DIR/.env，权限 600）─────────
SBX_DOMAIN=                       # 留空=用 hostname（须是 .com FQDN，否则报错）
SBX_CDN_DOMAIN=                   # 留空=hostname 把 .com 换成 .top
SBX_CODE=""                       # 写入 .env 的 code（敏感）；含特殊字符须加引号
SBX_COMPOSE_URL=https://raw.githubusercontent.com/currycan/sb-xray/main/docker-compose.yml

# ── 可选：ssrpolipo ──────────────────────────────────────
INSTALL_SSRPOLIPO=1               # 设 1 启用
SSRPOLIPO_COMPOSE_URL=            # 启用时必填：ssrpolipo docker-compose.yml 下载地址

# ── 可选：dotfiles（.bashrc / .vimrc）─────────────────────
# 留空则跳过。拉取到 root 与 sudo 用户家目录（curl 覆盖，幂等）。
# 不在入库脚本里硬编码个人 repo，真实地址写在此处（initial.env 不入库）。
BASHRC_URL=                       # 如 https://raw.githubusercontent.com/<you>/<repo>/master/bashrc
VIMRC_URL=                        # 如 https://raw.githubusercontent.com/<you>/<repo>/master/vimrc

# ── 可选：tcp-brutal DKMS 模块（Hysteria 2 brutal 拥塞控制）─
# 设 1 安装 apernet 官方 tcp-brutal 内核模块（DKMS，针对当前内核编译，
# 不替换内核/不需重启换核）。装完会打印 dkms status。
INSTALL_TCP_BRUTAL=1
TCP_BRUTAL_URL=https://tcp.hy2.sh/

# ════════════════════════════════════════════════════════════
# 回国（CN-exit）项 —— 同一文件共用：Stage 1 据此写全 .env，Stage 2 校验后做运行时
# 给定 OPENWRT_TS_IP 即判定本机为 CN-exit 节点：Stage 1 据此写全回国 .env（mode/tsip/
# ENABLE_*/按角色 WATCHTOWER_SCHEDULE）；Stage 2 校验后做运行时。非回国节点留空即可。
# ════════════════════════════════════════════════════════════
OPENWRT_TS_IP=                    # CN-exit 必填：家里 OpenWrt 的 Tailscale IP（100.x，socks5 腿回国出口）；也是 Stage 1 写回国 .env 的开关
TS_AUTHKEY=                       # 首次装 tailscale 必填：reusable auth key（敏感）
TS_AUTHKEY_FILE=                  # 改从文件读 authkey（TS_AUTHKEY 为空时生效）
TS_HOSTNAME=                      # 本机在 tailnet 的设备名（空=用 hostname）
CN_EXIT_MODE=balance             # 回国模式（默认 balance）
VPS_DOMAIN=                       # 本节点对外域名（写进 .env 的 domain；与 Stage 1 的 SBX_DOMAIN 取值需一致）
SBX_CANARY_ROLE=worker           # watchtower 角色 canary|worker —— Stage 1 据此写 WATCHTOWER_SCHEDULE（canary=北京 03:00 先行，worker 走 compose 默认 04:00）
REVERSE_DOMAINS=                  # 经 bridge 出的内网域名，逗号分隔（多节点建议统一）
SHOUTRRR_URLS=                    # 事件总线告警 URL（可选）
# 以下由 Stage 2 provision 给 cron 脚本（cn-exit-watchdog），人只在此填一次：
WD_TG_TOKEN=                      # CN 出口反向探活 Telegram bot token（与 WD_TG_CHAT 同时有值才装）
WD_TG_CHAT=                       # 反向探活 Telegram chat id
