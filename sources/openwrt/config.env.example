# sb-xray OpenWrt 一键初始化配置（回国出口 + OpenClash 配置纳管 + CDN 优选）
#
# 用法：复制本文件为 config.env，填好下面的值，再运行 ./openwrt-init.sh
#   cp config.env.example config.env
#   vi config.env
#   sh openwrt-init.sh
#
# 所有值都来自 VPS 服务端。VPS 上运行 `docker exec sb-xray show`，
# 输出里能找到域名、订阅 token、以及 reverse bridge 下载链接。

# ── 方案开关 ──────────────────────────────────────────────────────

# 回国方案（与 VPS 服务端 CN_EXIT_MODE 对齐）：
#   socks5   仅装 Tailscale（VPS 经 OpenClash SOCKS5 回国）—— 需 PEER_TS_IP/TS_HOSTNAME/TS_VERSION
#   reverse  仅装 xray reverse bridge —— 需 SUBSCRIBE_TOKEN/XRAY_VERSION
#   balance  两者都装（VPS 侧主备故障转移，推荐）—— 上述变量都需要
# 默认 balance（与 VPS 服务端 docker-compose 默认一致）；留空也按 balance 处理。
CN_EXIT_MODE=balance

# ── 必填（所有模式）────────────────────────────────────────────────

# VPS 域名（不要带 https:// 前缀）。单节点旧用法：填这一个 + 下方 SUBSCRIBE_TOKEN。
# 多节点高可用请改用下方 BRIDGE_NODES（此时 VPS_DOMAIN 可留空）。
# 用于：reverse bridge 连接目标、OpenClash 解耦的 DIRECT 规则 / fake-ip 过滤。
VPS_DOMAIN=vpn.example.com

# ── 多节点高可用（推荐；与单节点 VPS_DOMAIN 二选一）──────────────────

# 推荐：维护多行节点清单文件（见 nodes.list.example），每行 <名> <FQDN> <token>。
# openwrt-init.sh 优先读脚本同目录的 nodes.list；也可用 NODES_FILE 指定别的路径。
#   cp nodes.list.example nodes.list && vi nodes.list
# NODES_FILE=/etc/cn-exit/nodes.list

# 备选（内联，仅在无 nodes.list 文件时生效）：全部节点池写一行，每项 "名:FQDN:token"
# 空格分隔，token 各异（为各 VPS show 输出链接 ?token= 后那段）。
# BRIDGE_NODES="dc99:dc99.example.com:tokA jp:jp.example.com:tokB cn2:cn2.example.com:tokC"

# 常驻拨通的热备节点（裸名，逗号分隔）；其余为冷备，平时不拨、故障时
# `cn-bridge up <名>` 一条命令顶上。未设则拨清单内全部节点。
# BRIDGE_HOT=dc99,jp

# ── reverse / balance 模式必填 ────────────────────────────────────

# 订阅 token：VPS `show` 输出的下载链接 ?token=xxx 后面那段。
# 用于带鉴权下载已渲染好的 reverse bridge 落地机配置。
SUBSCRIBE_TOKEN=

# Xray-core release tag，不含前缀 v（脚本会自动拼成 v${XRAY_VERSION}）。
XRAY_VERSION=26.3.27

# ── socks5 / balance 模式必填 ─────────────────────────────────────

# 对端（VPS）的 Tailscale IP，形如 100.x.y.z。
# 用于 keepalive 定时 ping，缓解双重 NAT 下的空闲掉线。
# VPS 上 `tailscale ip -4` 获取。
PEER_TS_IP=100.0.0.0

# 可选：keepalive 保活目标列表（逗号分隔的 Tailscale IP），默认 = PEER_TS_IP。
# 多热备时填多个，任一在线即维持 openwrt 的 41641 出站映射；EIM NAT 下该映射
# 惠及全部 VPS 的直连，故无需逐台 ping。
# KEEPALIVE_PEERS=100.x.x.x,100.y.y.y

# 本机（这台 OpenWrt）在 Tailscale 网络里的 hostname。
TS_HOSTNAME=openwrt-cn

# Tailscale 版本，对应 https://pkgs.tailscale.com/stable/ 下载路径。
TS_VERSION=1.98.4

# ── 可选 ──────────────────────────────────────────────────────────

# 架构覆盖。留空 = 自动 uname -m 检测；可填 arm64 或 amd64 强制指定。
ARCH_OVERRIDE=

# tailscaled 固定 UDP 端口。默认 41641，除非端口冲突否则别改
# （固定端口是双重 NAT 下打洞稳定 + OpenClash 防火墙放行规则的前提）。
TS_PORT=41641

# subnet router 通告的内网网段（必填，socks5/balance 模式；填本机实际 lan 网段，如 192.168.1.0/24）。
# tailnet 其他设备经本机访问该网段；连同 exit node 一起，需到 Tailscale 管理后台批准。
# LAN 网段变更时同步改这里并重跑脚本即可（up --reset 自动撤销旧通告；自检有
# 「通告含本机实际网段」护栏，忘改会直接 FAIL）。迁移步骤见 README §5.5。
TS_ADVERTISE_ROUTES=

# 安装末尾是否自动 reload OpenClash 使解耦规则（DIRECT + fake-ip）立即生效。
# 0 = 仅打印提示，由你手动重载；1 = 脚本自动 reload。
RELOAD_OPENCLASH=0

# 外部下载（Tailscale / Xray / client.json）失败重试次数。
DOWNLOAD_RETRIES=3

# ── Tailscale 身份自恢复（可选，设备重置零断点的关键）──────────────
# 设备重置后 Tailscale state 丢失 → 新身份新 IP，而所有 VPS 的 CN_EXIT_SOCKS5_HOST
# 写死本机固定 IP。配好下面四项后，重置恢复 = 上传文件 + 跑脚本，全程无人值守：
# 免交互登录（OAuth 现场铸 key）→ API 删旧设备并恢复固定 IP → API 批准 routes。
# 不配则维持旧行为：打印登录 URL 手动授权 + 后台手动改 IP / 批准。
#
# OAuth client 在 https://login.tailscale.com/admin/settings/oauth 一次性创建
# （Select scopes 只勾三项写权限：Devices→Core、Devices→Routes、Keys→Auth Keys），
# 永不过期——灾备凭据不会腐烂。
# 注意：OAuth 铸的 key 必须带 tag，tailnet policy 须先定义 tagOwners（见 README §2.3）。
# TS_OAUTH_CLIENT_ID=
# TS_OAUTH_CLIENT_SECRET=

# OAuth 铸 key 所带 tag（逗号分隔），须与 tailnet policy 的 tagOwners 定义一致。
# TS_OAUTH_TAGS=tag:openwrt

# 本机应持有的固定 Tailscale IP（即 VPS 侧 .env 的 tsip 指向的值）。
# 设置后脚本/自检会校验并自动恢复；强烈建议设置。
# TS_EXPECTED_IP=100.x.y.z

# 显式 auth key（优先于 OAuth 铸造）。普通 auth key 最长 90 天过期，
# 只适合短期场景；长期灾备请用上面的 OAuth client。
# TS_AUTH_KEY=

# ── OpenClash 配置纳管（可选，默认开）──────────────────────────────
# 按架构选 op-amd/op-arm 模板，注入下面的私有值后幂等应用到 /etc/config/openclash
# （有差异才写，写前留 .bak.<时间戳>；生效需 restart，见 RELOAD_OPENCLASH）。
# 模板里未提供订阅地址的 config_subscribe 块（AllOne / 示例）会被整块裁剪。

# 0 = 不碰 /etc/config/openclash（只走钩子/规则注入的旧行为）。
# OPENCLASH_MANAGE=1

# dashboard 登录密码（纳管开启时必填，注入模板占位符 <OPENCLASH_DASHBOARD_PASSWORD>）。
# OPENCLASH_DASHBOARD_PASSWORD=

# 订阅地址注入："名=URL" 空格分隔多项，按模板 config_subscribe 块的 option name 匹配。
# OPENCLASH_SUBS="OneSmartPro=https://sub.example.com/OneSmartPro.yaml?token=xxx FallBackPro=https://sub.example.com/FallBackPro.yaml?token=xxx"

# ── CDN IP 优选（可选，CDN_DOMAIN 非空才启用）──────────────────────
# 内嵌 cdn-speedtest 写出 /usr/bin/cdn-speedtest + /etc/subdomains.txt + 每日 cron，
# Cloudflare 测速优选 IP 写入 /etc/hosts（sh openwrt-init.sh cdn status / clean 查看与回退）。
# 首次启用（无历史优选结果）时安装收尾会前台同步首跑一次（约几分钟，期间 OpenClash
# 暂停、测完自动恢复）；此后由每日 cron 维持。改 CDN_* 后可用 `sh openwrt-init.sh cdn`
# 单独重跑本段，不动其余配置。

# CDN 根域名；子域名前缀与之拼接成完整域名（如 node1.example.com）。
# CDN_DOMAIN=example.com

# 子域名前缀清单（逗号分隔），写入 /etc/subdomains.txt。
# 留空则沿用路由器上已有的 /etc/subdomains.txt。
# CDN_SUBDOMAINS=node1,node2

# 测速 cron 时间表，默认每天 04:00。
# CDN_CRON_SCHEDULE=0 4 * * *

# 测速参数（可选；设置后对首跑与每日 cron 同时生效，默认值见括号）。
# SPEED_TEST_THREADS=500        # 延迟测速线程数（500）
# SPEED_TEST_TIME=4             # 下载测速时间秒（4）
# SPEED_TEST_COUNT=5            # 下载测速数量（5）
# SPEED_TEST_LATENCY_MAX=200    # 延迟上限 ms（200）
# SPEED_TEST_MIN_SPEED=5        # 最低下载速度 MB/s（5）

# ── 监控告警（可选）────────────────────────────────────────────────
# cn-bridge-monitor 周期探活：热备 r-tunnel 隧道 + Tailscale 守护/离线 peer，
# 连续失败达阈值后 telegram 告警、恢复后发通知。留空 token 则只记录不告警。
# telegram bot token 与 chat id（与 VPS shoutrrr 用的同一个 bot 即可）。
# ALERT_TG_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALERT_TG_CHAT=-1001234567890
# 探活周期（分钟）与去抖阈值（连续失败多少次才告警）。
# MON_INTERVAL=2
# MON_THRESHOLD=3
