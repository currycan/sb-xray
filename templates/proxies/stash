proxies:
  - name: ${FLAG_PREFIX}Hysteria2 ✈ ${NODE_NAME}${NODE_SUFFIX}
    type: hysteria2
    server: ${DOMAIN}
    port: ${PORT_HYSTERIA2}
    sni: ${DOMAIN}
    obfs: salamander
    obfs-password: ${SB_UUID}
    alpn:
      - h3
    up: 2500 Mbps
    down: 2500 Mbps
    password: ${SB_UUID}
    skip-cert-verify: false

  - name: ${FLAG_PREFIX}TUIC ✈ ${NODE_NAME}${NODE_SUFFIX}
    type: tuic
    server: ${DOMAIN}
    port: ${PORT_TUIC}
    uuid: ${SB_UUID}
    password: ${SB_UUID}
    alpn:
      - h3
    sni: ${DOMAIN}
    reduce-rtt: true
    request-timeout: 8000
    udp-relay-mode: native
    congestion-controller: bbr
    skip-cert-verify: false
    version: 5

  - name: ${FLAG_PREFIX}Vmess ✈ ${NODE_NAME}${NODE_SUFFIX}
    type: vmess
    server: ${CDNDOMAIN}
    port: ${LISTENING_PORT}
    uuid: ${XRAY_UUID}
    alterId: 0
    cipher: auto
    tls: true
    client-fingerprint: chrome
    alpn:
      - h2
    skip-cert-verify: false
    network: ws
    ws-opts:
      headers:
        Host: ${CDNDOMAIN}
      path: /${XRAY_URL_PATH}-vmessws
    servername: ${CDNDOMAIN}

  - name: ${FLAG_PREFIX}Reality ✈ ${NODE_NAME}${NODE_SUFFIX}
    type: vless
    server: ${DOMAIN}
    port: ${LISTENING_PORT}
    uuid: ${XRAY_UUID}
    tls: true
    flow: xtls-rprx-vision
    client-fingerprint: chrome
    skip-cert-verify: false
    reality-opts:
      public-key: ${XRAY_REALITY_PUBLIC_KEY}
      short-id: ${XRAY_REALITY_SHORTID}
      _spider-x: /
    network: tcp
    servername: ${DEST_HOST}
