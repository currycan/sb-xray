{
    "_comment": "XHTTP/3 入站（adv 轨，H3 客户端必然 Xray-core 26.3.27+，直接内嵌 adv 字段）；直接监听 UDP/PORT_XHTTP_H3 + BBR 拥塞 + xPadding 新字段；绕开 nginx 直连内核；finalmask.fragment 是 TCP-only，H3 用 finalmask.quicParams 做 QUIC 级整形",
    "inbounds": [
        {
            "listen": "::",
            "port": ${PORT_XHTTP_H3},
            "protocol": "vless",
            "tag": "XHTTP_H3_IN",
            "settings": {
                "clients": [
                    {
                        "id": "${XRAY_UUID}",
                        "level": 0,
                        "email": "vless@xhttp.h3"
                    }
                ],
                "decryption": "mlkem768x25519plus.native.600s.${XRAY_MLKEM768_SEED}"
            },
            "streamSettings": {
                "network": "xhttp",
                "xhttpSettings": {
                    "host": "",
                    "path": "/${XRAY_URL_PATH}-xhttp-h3",
                    "mode": "auto",
                    "extra": {
                        "noSSEHeader": true,
                        "scMaxEachPostBytes": 1000000,
                        "scMaxBufferedPosts": 30,
                        "xPaddingBytes": "100-1000",
                        "xPaddingQueryParam": "cf_ray_id",
                        "xPaddingPlacement": "cookie",
                        "UplinkDataPlacement": "auto"
                    }
                },
                "security": "tls",
                "tlsSettings": {
                    "alpn": ["h3"],
                    "minVersion": "1.3",
                    "certificates": [
                        {
                            "certificateFile": "${SSL_PATH}/sb_xray_bundle.crt",
                            "keyFile": "${SSL_PATH}/sb_xray_bundle.key"
                        }
                    ]
                },
                "finalmask": {
                    "quicParams": {
                        "congestion": "bbr"
                    }
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": ["http", "tls"],
                "metadataOnly": false,
                "routeOnly": true
            }
        }
    ]
}
