{
    ${XRAY_OBSERVATORY_SECTION}
    "log": {
        "access": "${LOGDIR}/xray/access.log",
        "error": "${LOGDIR}/xray/error.log",
        "loglevel": "${LOG_LEVEL}",
        "maskAddress": "/16+/64"
    },
    "dns": {
        "enableParallelQuery": true,
        "servers": [
            {
                "address": "https+local://cloudflare-dns.com/dns-query",
                "serveStale": true,
                "serveExpiredTTL": 60
            },
            "1.1.1.1",
            "1.0.0.1",
            "8.8.8.8",
            "8.8.4.4"
        ]
    },
    "api": {
        "tag": "api",
        "services": [
            "HandlerService",
            "LoggerService",
            "StatsService"
        ]
    },
    "stats": {},
    "policy": {
        "levels": {
            "0": {
                "handshake": 8,
                "connIdle": 797,
                "uplinkOnly": 8,
                "downlinkOnly": 11,
                "statsUserUplink": true,
                "statsUserDownlink": true
            }
        },
        "system": {
            "statsInboundUplink": true,
            "statsInboundDownlink": true,
            "statsOutboundUplink": true,
            "statsOutboundDownlink": true
        }
    },
    "routing": {
        "domainStrategy": "IPIfNonMatch",
        ${XRAY_BALANCERS_SECTION}
        "rules": [
            {
                "type": "field",
                "ruleTag": "api",
                "inboundTag": [
                    "api"
                ],
                "outboundTag": "api"
            },
            {
                "type": "field",
                "ruleTag": "bt",
                "protocol": [
                    "bittorrent"
                ],
                "marktag": "ban_bt",
                "outboundTag": "block",
                "webhook": {
                    "url": "http://127.0.0.1:18085/ban_bt",
                    "deduplication": 300,
                    "headers": {
                        "X-Event": "ban_bt"
                    }
                }
            },
            {
                "type": "field",
                "ruleTag": "cn-ip",
                "ip": [
                    "geoip:cn"
                ],
                "marktag": "ban_geoip_cn",
                "outboundTag": "block",
                "webhook": {
                    "url": "http://127.0.0.1:18085/ban_geoip_cn",
                    "deduplication": 600,
                    "headers": {
                        "X-Event": "ban_geoip_cn"
                    }
                }
            },
            {
                "type": "field",
                "ruleTag": "ad-domain",
                "domain": [
                    "geosite:category-ads-all"
                ],
                "outboundTag": "block",
                "webhook": {
                    "url": "http://127.0.0.1:18085/ban_ads",
                    "deduplication": 900,
                    "headers": {
                        "X-Event": "ban_ads"
                    }
                }
            },
            ${XRAY_SERVICE_RULES}
            {
                "type": "field",
                "ruleTag": "private-ip",
                "ip": [
                    "geoip:private"
                ],
                "outboundTag": "block",
                "webhook": {
                    "url": "http://127.0.0.1:18085/ban_private_ip",
                    "deduplication": 1800,
                    "headers": {
                        "X-Event": "ban_private_ip"
                    }
                }
            }
        ]
    },
    "inbounds": [
        {
            "tag": "api",
            "port": 7978,
            "listen": "127.0.0.1",
            "protocol": "dokodemo-door",
            "settings": {
                "address": "127.0.0.1"
            }
        }
    ],
    "outbounds": [
        {
            "tag": "direct",
            "protocol": "freedom",
            "settings": {
                "domainStrategy": "UseIPv4v6"
            }
        },
        ${CUSTOM_OUTBOUNDS}
        {
            "tag": "block",
            "protocol": "blackhole"
        }
    ]
}
